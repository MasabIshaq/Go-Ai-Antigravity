:root {
  --bg-primary: #212121;
  --bg-sidebar: #171717;
  --bg-user-row: #303030;
  --bg-input: #2f2f2f;
  --bg-hover: #2a2a2a;
  --bg-active: #343434;
  --text-primary: #ececec;
  --text-secondary: #b4b4b4;
  --text-muted: #8e8e8e;
  --border: #424242;
  --accent: #10a37f;
  --sidebar-width: 260px;
  --topbar-height: 52px;
  --content-max: 768px;
  --font: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html, body {
  height: 100%;
  font-family: var(--font);
  background: var(--bg-primary);
  color: var(--text-primary);
  -webkit-font-smoothing: antialiased;
}

.hidden { display: none !important; }

/* Splash */
.splash {
  position: fixed;
  inset: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #000;
  transition: opacity 0.5s ease, visibility 0.5s;
}

.splash.hide {
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  display: none !important;
}

.splash-logo {
  width: 120px;
  height: 120px;
  object-fit: contain;
  animation: splashPulse 2s ease-in-out infinite;
}

@keyframes splashPulse {
  0%, 100% { transform: scale(1); opacity: 0.85; }
  50% { transform: scale(1.08); opacity: 1; }
}

/* Auth */
.auth-screen {
  position: fixed;
  inset: 0;
  z-index: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-primary);
  padding: 24px;
}

.auth-card {
  width: 100%;
  max-width: 400px;
  text-align: center;
}

.auth-logo {
  width: 56px;
  height: 56px;
  margin-bottom: 16px;
}

.auth-card h1 {
  font-size: 1.75rem;
  font-weight: 600;
  margin-bottom: 4px;
}

.auth-tagline {
  color: var(--text-muted);
  margin-bottom: 24px;
}

.auth-tabs {
  display: flex;
  gap: 8px;
  margin-bottom: 20px;
}

.auth-tab {
  flex: 1;
  padding: 10px;
  border: 1px solid var(--border);
  border-radius: 8px;
  background: transparent;
  color: var(--text-secondary);
  cursor: pointer;
  font-size: 0.9rem;
}

.auth-tab.active {
  background: var(--bg-active);
  color: var(--text-primary);
  border-color: var(--accent);
}

.auth-form {
  display: flex;
  flex-direction: column;
  gap: 14px;
  text-align: left;
}

.auth-form label {
  display: flex;
  flex-direction: column;
  gap: 6px;
  font-size: 0.85rem;
  color: var(--text-secondary);
}

.auth-form input {
  padding: 12px 14px;
  border: 1px solid var(--border);
  border-radius: 8px;
  background: var(--bg-input);
  color: var(--text-primary);
  font-size: 1rem;
}

.auth-form input:focus {
  outline: none;
  border-color: var(--accent);
}

.auth-error {
  color: #f87171;
  font-size: 0.85rem;
  min-height: 1.2em;
}

.btn-primary {
  padding: 12px;
  border: none;
  border-radius: 8px;
  background: var(--accent);
  color: #fff;
  font-size: 1rem;
  font-weight: 500;
  cursor: pointer;
}

.btn-primary:hover { filter: brightness(1.1); }

/* App layout */
.app {
  display: flex;
  height: 100vh;
  overflow: hidden;
}

.app.sidebar-collapsed .sidebar {
  transform: translateX(-100%);
}

.sidebar {
  width: var(--sidebar-width);
  min-width: var(--sidebar-width);
  background: var(--bg-sidebar);
  display: flex;
  flex-direction: column;
  border-right: 1px solid var(--border);
  transition: transform 0.2s ease;
}

.sidebar-header {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 14px 12px;
  border-bottom: 1px solid var(--border);
}

.sidebar-brand {
  flex: 1;
  font-weight: 600;
  font-size: 0.95rem;
}

.sidebar-top {
  padding: 12px;
}

.btn-new-chat {
  display: flex;
  align-items: center;
  gap: 10px;
  width: 100%;
  padding: 10px 12px;
  border: 1px solid var(--border);
  border-radius: 8px;
  background: transparent;
  color: var(--text-primary);
  cursor: pointer;
  font-size: 0.9rem;
}

.btn-new-chat:hover { background: var(--bg-hover); }

.sidebar-section-grow {
  flex: 1;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  padding: 0 8px;
}

.sidebar-label {
  font-size: 0.75rem;
  color: var(--text-muted);
  padding: 8px 8px 4px;
  text-transform: uppercase;
  letter-spacing: 0.04em;
}

.chat-list {
  flex: 1;
  overflow-y: auto;
  padding-bottom: 8px;
}

.sidebar-empty {
  color: var(--text-muted);
  font-size: 0.85rem;
  padding: 12px 8px;
}

.chat-row {
  position: relative;
  display: flex;
  align-items: center;
  border-radius: 8px;
  margin-bottom: 2px;
}

.chat-row:hover { background: var(--bg-hover); }
.chat-row.active { background: var(--bg-active); }

.chat-item {
  flex: 1;
  padding: 10px 36px 10px 12px;
  border: none;
  background: transparent;
  color: var(--text-primary);
  text-align: left;
  font-size: 0.875rem;
  cursor: pointer;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.chat-menu-btn {
  position: absolute;
  right: 4px;
  width: 28px;
  height: 28px;
  border: none;
  border-radius: 6px;
  background: transparent;
  color: var(--text-muted);
  cursor: pointer;
  opacity: 0;
}

.chat-row:hover .chat-menu-btn { opacity: 1; }
.chat-menu-btn:hover { background: var(--bg-active); color: var(--text-primary); }

.chat-dropdown {
  position: absolute;
  right: 4px;
  top: 100%;
  z-index: 50;
  min-width: 120px;
  background: var(--bg-input);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 4px;
  box-shadow: 0 8px 24px rgba(0,0,0,0.4);
}

.chat-dropdown-item {
  display: block;
  width: 100%;
  padding: 8px 12px;
  border: none;
  border-radius: 6px;
  background: transparent;
  color: var(--text-primary);
  text-align: left;
  font-size: 0.85rem;
  cursor: pointer;
}

.chat-dropdown-item:hover { background: var(--bg-hover); }
.chat-dropdown-item.danger { color: #f87171; }

.sidebar-footer {
  padding: 12px;
  border-top: 1px solid var(--border);
}

.profile-wrap { position: relative; }

.profile-btn {
  display: flex;
  align-items: center;
  gap: 10px;
  width: 100%;
  padding: 8px;
  border: none;
  border-radius: 8px;
  background: transparent;
  color: var(--text-primary);
  cursor: pointer;
  text-align: left;
}

.profile-btn:hover { background: var(--bg-hover); }

.profile-avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: var(--accent);
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  font-size: 0.85rem;
  flex-shrink: 0;
}

.profile-name {
  font-size: 0.875rem;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-menu {
  position: absolute;
  bottom: 100%;
  left: 0;
  right: 0;
  margin-bottom: 8px;
  background: var(--bg-input);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 8px;
  box-shadow: 0 8px 24px rgba(0,0,0,0.4);
}

.profile-menu-email {
  font-size: 0.8rem;
  color: var(--text-muted);
  padding: 4px 8px 8px;
  word-break: break-all;
}

.profile-menu-item {
  display: block;
  width: 100%;
  padding: 8px 12px;
  border: none;
  border-radius: 6px;
  background: transparent;
  color: var(--text-primary);
  text-align: left;
  cursor: pointer;
  font-size: 0.875rem;
}

.profile-menu-item:hover { background: var(--bg-hover); }
.profile-menu-danger { color: #f87171; }

.btn-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border: none;
  border-radius: 8px;
  background: transparent;
  color: var(--text-secondary);
  cursor: pointer;
}

.btn-icon:hover { background: var(--bg-hover); color: var(--text-primary); }

/* Main */
.main {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
  background: var(--bg-primary);
}

.topbar {
  display: flex;
  align-items: center;
  gap: 12px;
  height: var(--topbar-height);
  padding: 0 16px;
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}

.topbar-title {
  font-size: 1rem;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.messages-wrap {
  flex: 1;
  overflow-y: auto;
  scroll-behavior: smooth;
}

.welcome {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 50vh;
  padding: 40px 24px;
  text-align: center;
}

.welcome-img {
  width: 64px;
  height: 64px;
  margin-bottom: 16px;
}

.welcome-sub {
  font-size: 1.25rem;
  color: var(--text-secondary);
  margin-bottom: 24px;
}

.suggestions {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  justify-content: center;
  max-width: 600px;
}

.suggestion {
  padding: 10px 16px;
  border: 1px solid var(--border);
  border-radius: 20px;
  background: transparent;
  color: var(--text-secondary);
  font-size: 0.875rem;
  cursor: pointer;
}

.suggestion:hover {
  background: var(--bg-hover);
  color: var(--text-primary);
}

/* ChatGPT-style full-width turns */
.thread { width: 100%; }

.turn {
  width: 100%;
  border-bottom: 1px solid transparent;
}

.turn-user {
  background: var(--bg-user-row);
}

.turn-assistant {
  background: var(--bg-primary);
}

.turn-inner {
  max-width: var(--content-max);
  margin: 0 auto;
  padding: 24px 16px;
  display: flex;
  gap: 16px;
  align-items: flex-start;
}

.turn-user .turn-inner {
  display: block;
}

.turn-user-text {
  font-size: 1rem;
  line-height: 1.6;
  white-space: pre-wrap;
  word-break: break-word;
}

.bot-logo {
  width: 28px;
  height: 28px;
  flex-shrink: 0;
  border-radius: 4px;
}

.turn-content {
  flex: 1;
  min-width: 0;
  font-size: 1rem;
  line-height: 1.6;
  word-break: break-word;
}

.turn-content p { margin-bottom: 12px; }
.turn-content p:last-child { margin-bottom: 0; }
.turn-content ul, .turn-content ol { margin: 0 0 12px 1.25em; }

.turn-content pre {
  position: relative;
  margin: 12px 0;
  padding: 14px;
  border-radius: 8px;
  background: #1a1a1a;
  overflow-x: auto;
}

.turn-content code {
  font-family: ui-monospace, "Cascadia Code", monospace;
  font-size: 0.875em;
}

.turn-content :not(pre) > code {
  padding: 2px 6px;
  border-radius: 4px;
  background: rgba(255,255,255,0.08);
}

.turn-content pre code {
  padding: 0;
  background: none;
}

.copy-btn {
  position: absolute;
  top: 8px;
  right: 8px;
  padding: 4px 10px;
  border: 1px solid var(--border);
  border-radius: 6px;
  background: var(--bg-input);
  color: var(--text-secondary);
  font-size: 0.75rem;
  cursor: pointer;
  opacity: 0;
  transition: opacity 0.15s;
}

.turn-content pre:hover .copy-btn { opacity: 1; }

.typing-cursor::after {
  content: "▋";
  animation: blink 0.8s step-end infinite;
  color: var(--accent);
  margin-left: 2px;
}

@keyframes blink {
  50% { opacity: 0; }
}

/* Composer */
.composer-wrap {
  flex-shrink: 0;
  padding: 16px;
  background: linear-gradient(transparent, var(--bg-primary) 20%);
}

.composer {
  max-width: var(--content-max);
  margin: 0 auto;
}

.composer-inner {
  display: flex;
  align-items: flex-end;
  gap: 8px;
  padding: 12px 14px;
  border: 1px solid var(--border);
  border-radius: 24px;
  background: var(--bg-input);
}

.composer-inner textarea {
  flex: 1;
  border: none;
  background: transparent;
  color: var(--text-primary);
  font-size: 1rem;
  font-family: inherit;
  line-height: 1.5;
  resize: none;
  max-height: 200px;
  outline: none;
}

.composer-inner textarea::placeholder { color: var(--text-muted); }

.btn-send {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border: none;
  border-radius: 50%;
  background: var(--accent);
  color: #fff;
  cursor: pointer;
  flex-shrink: 0;
}

.btn-send:disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

.composer-hint {
  text-align: center;
  font-size: 0.75rem;
  color: var(--text-muted);
  margin-top: 8px;
}

/* Overlay */
.sidebar-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
}

.sidebar-overlay.visible { display: block; }

/* Dialog */
.dialog-overlay {
  position: fixed;
  inset: 0;
  z-index: 1100;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,0.6);
  padding: 24px;
}

.dialog-card {
  width: 100%;
  max-width: 400px;
  padding: 24px;
  background: var(--bg-input);
  border: 1px solid var(--border);
  border-radius: 12px;
}

.dialog-card h3 { margin-bottom: 8px; }
.dialog-card p { color: var(--text-secondary); margin-bottom: 16px; }

.dialog-input {
  width: 100%;
  padding: 10px 12px;
  margin-bottom: 16px;
  border: 1px solid var(--border);
  border-radius: 8px;
  background: var(--bg-primary);
  color: var(--text-primary);
}

.dialog-actions {
  display: flex;
  gap: 10px;
  justify-content: flex-end;
}

.btn-dialog-secondary,
.btn-dialog-danger {
  padding: 8px 16px;
  border-radius: 8px;
  border: 1px solid var(--border);
  cursor: pointer;
  font-size: 0.9rem;
}

.btn-dialog-secondary {
  background: transparent;
  color: var(--text-primary);
}

.btn-dialog-danger {
  background: #dc2626;
  border-color: #dc2626;
  color: #fff;
}

/* Mobile */
@media (max-width: 768px) {
  .sidebar {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    z-index: 200;
    transform: translateX(-100%);
  }

  .sidebar.open { transform: translateX(0); }

  .app:not(.sidebar-collapsed) .sidebar {
    transform: translateX(-100%);
  }

  .app.sidebar-collapsed .sidebar {
    transform: translateX(-100%);
  }
}
